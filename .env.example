DEBUG=true
HOST=127.0.0.1
PORT=8080
FLASK_SECRET_KEY=$(python3 -c "import secrets; print(secrets.token_hex(16))")
AI_MASTER_DOC_PATH=data/ai_master.md
DATABASE_PATH=data/ai_graph.db
MAX_GRAPH_NODES=10000
SIGNAL_SPAWN_RATE=0.008
API_GRAPH_RATE_LIMIT=90
API_REBUILD_RATE_LIMIT=4
RATE_LIMIT_WINDOW_SECONDS=60
HEALTH_CHECK_SAMPLE_LIMIT=5

# Scraper (Cloud Run Job) -----------------------------------------------------
# Required for story extraction (Google AI Studio key)
GEMINI_API_KEY=AIza...
# GCS bucket holding ai_stories.json + scrape_state.json.
# Unset = local files under data/ (development mode).
STORIES_BUCKET=
# Historical ingest options
AI_SEED_PATH=data/ai_history_seed.json
SEED_YEAR_FROM=1990
SEED_YEAR_TO=2012
SKIP_WAYBACK=0
